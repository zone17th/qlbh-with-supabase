# Frontend
VITE_API_BASE_URL=https://<project-ref>.functions.supabase.co/api/api/v1

# Supabase Edge Function runtime
# Deployed Edge Functions receive these reserved variables automatically:
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY
# Do not run `supabase secrets set SUPABASE_URL=...`; the CLI skips names
# starting with SUPABASE_.

# Optional local values
# VITE_API_BASE_URL=http://127.0.0.1:54321/functions/v1/api/api/v1
